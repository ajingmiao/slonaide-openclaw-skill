{
  "id": "slonaide",
  "name": "AideNote",
  "version": "3.0.5",
  "description": "AideNote recording notes and OpenClaw remote bridge",
  "main": "index.js",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": {
        "type": "string",
        "description": "AideNote API Key",
        "secret": true
      },
      "baseUrl": {
        "type": "string",
        "description": "AideNote API base URL",
        "default": "https://api.aidenote.cn"
      },
      "bridgeInstallerUrl": {
        "type": "string",
        "description": "macOS bridge installer script URL",
        "default": "https://cdn.aidenote.cn/tunnel/releases/3.2.2/install-macos.sh"
      },
      "bridgeInstallerSha256": {
        "type": "string",
        "description": "macOS bridge installer script SHA-256",
        "default": "8e673bf62dbf426f7f0313c0f4cbd97a988002064b77ed1dd98481fb0ddfdeb5"
      },
      "bridgeTunnelBaseUrl": {
        "type": "string",
        "description": "macOS bridge binary base URL",
        "default": "https://cdn.aidenote.cn/tunnel/releases/3.2.2"
      },
      "bridgeRelayHost": {
        "type": "string",
        "description": "AideNote relay host",
        "default": "api.aidenote.cn"
      },
      "openClawLocalPort": {
        "type": "number",
        "description": "Local OpenClaw Gateway port",
        "default": 18789
      }
    },
    "required": ["apiKey"]
  }
}
