{
  "id": "slonaide",
  "name": "AideNote",
  "version": "3.0.8",
  "description": "AideNote recording notes and OpenClaw remote bridge",
  "main": "index.js",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "apiKey": {
        "type": "string",
        "description": "AideNote API Key",
        "secret": true
      },
      "baseUrl": {
        "type": "string",
        "description": "AideNote API base URL",
        "default": "https://api.aidenote.cn"
      },
      "bridgeInstallerUrl": {
        "type": "string",
        "description": "macOS bridge installer script URL",
        "default": "https://cdn.aidenote.cn/tunnel/releases/3.2.6/install-macos.sh"
      },
      "bridgeInstallerSha256": {
        "type": "string",
        "description": "macOS bridge installer script SHA-256",
        "default": "5afb27d2640b73689217775989253c0cdea05c4f35ea0ee9f86bb4c0551070cd"
      },
      "bridgeWindowsInstallerUrl": {
        "type": "string",
        "description": "Windows bridge installer script URL",
        "default": "https://cdn.aidenote.cn/tunnel/releases/3.2.6/install-windows.ps1"
      },
      "bridgeWindowsInstallerSha256": {
        "type": "string",
        "description": "Windows bridge installer script SHA-256",
        "default": "5a5a3ecee34e3dce6d2248744bcac854296ed0f4c3afab0f3a344c9f36d908f6"
      },
      "bridgeTunnelBaseUrl": {
        "type": "string",
        "description": "bridge binary base URL",
        "default": "https://cdn.aidenote.cn/tunnel/releases/3.2.6"
      },
      "bridgeRelayHost": {
        "type": "string",
        "description": "AideNote relay host",
        "default": "api.aidenote.cn"
      },
      "openClawLocalPort": {
        "type": "number",
        "description": "Local OpenClaw Gateway port",
        "default": 18789
      }
    },
    "required": ["apiKey"]
  }
}
